[Unit]
Description=Cliphist Wayland clipboard watchers (text + images)
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/bash -lc 'wl-paste --type text --watch cliphist store >/dev/null 2>&1 & wl-paste --type image --watch cliphist store >/dev/null 2>&1 & wait'
Restart=on-failure
RestartSec=1

[Install]
WantedBy=graphical-session.target

