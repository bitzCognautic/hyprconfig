#!/usr/bin/env bash
set -euo pipefail

summary="${1:-}"
body="${2:-}"

log() { printf '%s\n' "$*" >>/tmp/eink-notify.log 2>/dev/null || true; }
log "---- $(date --iso-8601=seconds) ----"
log "summary=$summary"
log "DBUS_SESSION_BUS_ADDRESS=${DBUS_SESSION_BUS_ADDRESS:-}"
log "WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-}"

direct_ok=0
if command -v notify-send >/dev/null 2>&1; then
  notify-send -a Eink -u normal -t 2500 "$summary" "$body" >/tmp/eink-notify.direct.out 2>/tmp/eink-notify.direct.err || direct_ok=$?
  if [[ $direct_ok -eq 0 ]]; then
    log "direct=ok"
    exit 0
  fi
  log "direct=fail rc=$direct_ok err=$(tail -n 1 /tmp/eink-notify.direct.err 2>/dev/null || true)"
else
  log "direct=skip notify-send missing"
fi

# If we're missing DBus env (common when launched from shell/layers), borrow it from swaync.
if [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]] && command -v notify-send >/dev/null 2>&1; then
  swaync_pid="$(pgrep -n swaync 2>/dev/null || true)"
  if [[ -n "$swaync_pid" && -r "/proc/$swaync_pid/environ" ]]; then
    dbus_addr="$(tr '\0' '\n' <"/proc/$swaync_pid/environ" | awk -F= '$1=="DBUS_SESSION_BUS_ADDRESS"{print substr($0, index($0,$2))}' | head -n1)"
    xdg_rt="$(tr '\0' '\n' <"/proc/$swaync_pid/environ" | awk -F= '$1=="XDG_RUNTIME_DIR"{print substr($0, index($0,$2))}' | head -n1)"
    wl_disp="$(tr '\0' '\n' <"/proc/$swaync_pid/environ" | awk -F= '$1=="WAYLAND_DISPLAY"{print substr($0, index($0,$2))}' | head -n1)"

    if [[ -n "$dbus_addr" ]]; then
      log "borrowed=dbus"
      borrow_ok=0
      env \
        DBUS_SESSION_BUS_ADDRESS="$dbus_addr" \
        XDG_RUNTIME_DIR="${xdg_rt:-${XDG_RUNTIME_DIR:-}}" \
        WAYLAND_DISPLAY="${wl_disp:-${WAYLAND_DISPLAY:-}}" \
        notify-send -a Eink -u normal -t 2500 "$summary" "$body" \
        >/tmp/eink-notify.borrow.out 2>/tmp/eink-notify.borrow.err || borrow_ok=$?
      if [[ $borrow_ok -eq 0 ]]; then
        log "borrowed=ok"
        exit 0
      fi
      log "borrowed=fail rc=$borrow_ok err=$(tail -n 1 /tmp/eink-notify.borrow.err 2>/dev/null || true)"
    else
      log "borrowed=skip no dbus in swaync environ"
    fi
  else
    log "borrowed=skip swaync pid not found"
  fi
fi

# Fallback: try running under the user systemd environment (often has DBus vars).
if command -v systemd-run >/dev/null 2>&1 && command -v notify-send >/dev/null 2>&1; then
  sys_ok=0
  systemd-run --user --quiet --scope notify-send -a Eink -u normal -t 2500 "$summary" "$body" >/tmp/eink-notify.systemd.out 2>/tmp/eink-notify.systemd.err || sys_ok=$?
  if [[ $sys_ok -eq 0 ]]; then
    log "systemd=ok"
    exit 0
  fi
  log "systemd=fail rc=$sys_ok err=$(tail -n 1 /tmp/eink-notify.systemd.err 2>/dev/null || true)"
else
  log "systemd=skip missing systemd-run or notify-send"
fi

exit 0
